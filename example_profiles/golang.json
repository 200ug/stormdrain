{
    "name": "golang",
    "description": "golang (1.26.2) runtime, lsp, tooling, & standard mounts",
    "shell": "/bin/zsh",
    "packages": [
        "ripgrep", "zsh-autosuggestions", "fzf", "tmux", "tree",
        "gopls"
    ],
    "installers": [
        "curl -Lo /tmp/nvim-linux-x86_64.tar.gz https://github.com/neovim/neovim/releases/download/v0.12.1/nvim-linux-x86_64.tar.gz && tar -xzf /tmp/nvim-linux-x86_64.tar.gz -C /tmp && mkdir -p ~/.bin && cp /tmp/nvim-linux-x86_64/bin/nvim ~/.bin/ && chmod +x ~/.bin/nvim",
        "curl -L -o /tmp/go-linux-amd64.tar.gz https://go.dev/dl/go1.26.2.linux-amd64.tar.gz && sudo rm -rf /usr/local/go && sudo tar -C /usr/local -xzf /tmp/go-linux-amd64.tar.gz"
    ],
    "dotfiles": [
        { "src": "~/.config/nvim", "dst": "~/.config/nvim" },
        { "src": "~/.config/tmux", "dst": "~/.config/tmux" },
        { "src": "~/.zshrc", "dst": "~/." },
        { "src": "~/.config/zsh", "dst": "~/.config/zsh" }
    ],
    "workspace": {
        "direct_mounts": ["cmd", "internal", "scripts", "docs", "go.mod", "go.sum", "main.go"],
        "virtual_volumes": [
            { "path": "/go/pkg/mod", "name": "go-mod-cache" },
            { "path": "/home/dev/.cache/go-build", "name": "go-build-cache" }
        ]
    }
}
